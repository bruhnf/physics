# Copy to .env and adjust as needed.
DATABASE_URL="postgresql://stemlab:stemlab_dev_only@localhost:5433/stemlab?schema=public"
PORT=4000
NODE_ENV=development
# Leave empty (or set to *) in dev to allow any origin — the phone's dev client
# hits the backend over LAN with arbitrary host. In prod, comma-separated whitelist.
CORS_ORIGIN=
